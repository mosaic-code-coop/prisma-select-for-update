{
  "name": "prisma-lock-for-update",
  "version": "0.1.0",
  "description": "Prisma v7 extension for SELECT ... FOR UPDATE row locking",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:setup": "npm run db:up && sleep 2 && npm run db:push"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "@prisma/client": "^7.0.0"
  },
  "devDependencies": {
    "@prisma/client": "^7.0.0",
    "@types/node": "^25.0.3",
    "@types/pg": "^8.16.0",
    "prisma": "^7.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "prisma",
    "for-update",
    "row-locking",
    "select-for-update",
    "postgresql"
  ],
  "license": "MIT",
  "dependencies": {
    "@prisma/adapter-pg": "^7.2.0",
    "dotenv": "^17.2.3",
    "pg": "^8.16.3"
  }
}
